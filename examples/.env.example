# --- GitHub App credentials (required) -----------------------------------
# Create a GitHub App with these permissions:
#   Repository: Contents (read/write), Pull requests (read/write),
#               Metadata (read), Checks (read)
# Subscribe to events: Pull request
# Install on the orgs/repos you want covered.
GITHUB_APP_ID=123456
# Either an absolute path to the .pem file, or the inline PEM contents.
GITHUB_APP_PRIVATE_KEY=/etc/pr-conflict-bot/private-key.pem
GITHUB_WEBHOOK_SECRET=replace-me-with-a-long-random-string
# The login GitHub assigns to your App, with the [bot] suffix.
# Find it via: gh api /apps/<your-app-slug> | jq .slug  → then "<slug>[bot]"
GITHUB_BOT_LOGIN=pr-conflict-bot[bot]

# --- Org allowlist (recommended) ------------------------------------------
# Comma-separated lowercase GitHub org slugs. Empty = allow any org.
# ALLOW_ORGS=

# --- LLM backend (the model that resolves conflicts) ---------------------
# Two backends supported. Both are subscription-billed (no per-token API).
#   claude  — Claude Code CLI (`claude -p`). Auth via CLAUDE_CODE_OAUTH_TOKEN
#             generated by `claude setup-token` on a desktop logged in to
#             Claude Pro/Max. (Recommended.)
#   codex   — OpenAI Codex CLI (`codex exec`). Auth via `codex login` on host.
LLM_BACKEND=claude
# Path to the binary. Empty = default ("claude" or "codex" by backend).
LLM_BIN=
# Optional extra args passed through to the binary, space-separated.
# LLM_EXTRA_ARGS=

# --- Backend: claude -----------------------------------------------------
# Generate on a desktop logged into Claude Pro/Max:
#   claude setup-token
# The token is valid ~1 year. Paste it here. Stored only on the server.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Backend: codex ------------------------------------------------------
# Sandbox: read-only | workspace-write | danger-full-access
CODEX_SANDBOX=workspace-write

# --- Verify gate (defaults applied when a repo has no .pr-conflict-bot.toml) -
# Empty string = skip that step. The verify gate is the safety net — never
# disable all three in production.
VERIFY_LINT=
VERIFY_TYPECHECK=
VERIFY_TEST=
VERIFY_TIMEOUT=600

# Strict mode: refuse to attempt resolution unless the effective verify gate
# (env defaults + per-repo override) has at least one non-empty step. With
# this on, every covered repo must ship a .pr-conflict-bot.toml with verify
# commands or opt out via `[behavior] enabled = false`. Strongly recommended
# in production — the verify gate is the only thing that prevents pushing
# unverified merge resolutions.
REQUIRE_REPO_CONFIG=false

# --- Bot identity (commit author) -----------------------------------------
BOT_GIT_NAME=pr-conflict-bot
BOT_GIT_EMAIL=pr-conflict-bot@users.noreply.github.com

# --- Server -------------------------------------------------------------
LISTEN_HOST=127.0.0.1
LISTEN_PORT=8081
# The HTTP path the bot REGISTERS for webhooks. Whether this matches the
# public URL path depends on whether your reverse proxy strips the prefix:
#   - Tailscale Funnel `--set-path=/prbot` STRIPS the prefix → set
#     WEBHOOK_PATH=/hooks/github (not /prbot/hooks/github)
#   - nginx `location /prbot/ { proxy_pass http://backend/; }` (trailing slash)
#     also strips. Without trailing slash on the proxy_pass it does NOT strip.
#   - GitHub Action webhook reverse proxies vary.
# Test by curling the public URL's webhook path with no signature; if you get
# HTTP 401 "bad signature", the route matched. If 404, the path is wrong.
WEBHOOK_PATH=/hooks/github
WORK_DIR=/var/lib/pr-conflict-bot/work
LOG_LEVEL=INFO
